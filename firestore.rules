rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/entitlements/{docId} {
      allow read: if isOwner(userId) && docId == 'current';
      allow create: if isOwner(userId) && docId == 'current'
        && request.resource.data.keys().hasOnly([
          'plan',
          'manualAppTrialStartedAt',
          'manualAppTrialEndsAt',
          'cloudTrialStartedAt',
          'cloudTrialEndsAt',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isOwner(userId) && docId == 'current'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'plan',
          'manualAppTrialStartedAt',
          'manualAppTrialEndsAt',
          'cloudTrialStartedAt',
          'cloudTrialEndsAt',
          'revenueCatUserId',
          'revenueCatProActive',
          'revenueCatCloudBackupActive',
          'revenueCatProProductId',
          'revenueCatCloudBackupProductId',
          'lastSyncedAt',
          'updatedAt'
        ]);
    }

    match /users/{userId}/backups/{backupId} {
      allow read, write, delete: if isOwner(userId);
    }
  }
}
