platform :osx, '11.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# рҹ”‘ м¶”к°Җ: лӘЁл“Ҳ н—ӨлҚ” к°•м ң (м •м Ғ лқјмқҙлёҢлҹ¬лҰ¬ + Swift import к№Ём§җ л°©м§Җ)
use_modular_headers!

target 'Runner' do
  # вҡ пёҸ м ҲлҢҖ л„Јм§Җ л§җ кІғ: use_frameworks!
  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

def remove_weak_framework(flags, framework_name)
  filtered = []
  skip_next = false

  flags.each_with_index do |flag, index|
    if skip_next
      skip_next = false
      next
    end

    next_flag = flags[index + 1]&.delete('"')
    if flag == '-weak_framework' && next_flag == framework_name
      skip_next = true
      next
    end

    filtered << flag
  end

  filtered
end

def patch_cloud_firestore_macos_plugin
  plugin_path = File.join(
    __dir__,
    'Flutter',
    'ephemeral',
    '.symlinks',
    'plugins',
    'cloud_firestore',
    'macos',
    'cloud_firestore',
    'Sources',
    'cloud_firestore',
    'FLTFirebaseFirestorePlugin.m'
  )
  return unless File.exist?(plugin_path)

  text = File.read(plugin_path)
  original = text

  unless text.include?('+ (instancetype)sharedInstance:(NSObject<FlutterBinaryMessenger> *)messenger')
    text = text.sub(
      %r{// Returns a singleton instance of the Firebase Firestore plugin\.\n//\+ \(instancetype\)sharedInstance \{\n//  static dispatch_once_t onceToken;\n//  static FLTFirebaseFirestorePlugin \*instance;\n//\n//  dispatch_once\(&onceToken, \^\{\n//    instance = \[\[FLTFirebaseFirestorePlugin alloc\] init\];\n//    // Register with the Flutter Firebase plugin registry\.\n//    \[\[FLTFirebasePluginRegistry sharedInstance\] registerFirebasePlugin:instance\];\n//  \}\);\n//\n//  return instance;\n//\}},
      <<~'OBJC'.strip
      // Returns a singleton instance of the Firebase Firestore plugin.
      + (instancetype)sharedInstance:(NSObject<FlutterBinaryMessenger> *)messenger {
        static dispatch_once_t onceToken;
        static FLTFirebaseFirestorePlugin *instance;

        dispatch_once(&onceToken, ^{
          instance = [[FLTFirebaseFirestorePlugin alloc] init:messenger];
          // Register with the Flutter Firebase plugin registry.
          [[FLTFirebasePluginRegistry sharedInstance] registerFirebasePlugin:instance];
        });

        return instance;
      }
      OBJC
    )
  end

  text = text.sub(
    "FLTFirebaseFirestorePlugin *instance =\n      [[FLTFirebaseFirestorePlugin alloc] init:[registrar messenger]];",
    "FLTFirebaseFirestorePlugin *instance =\n      [FLTFirebaseFirestorePlugin sharedInstance:[registrar messenger]];"
  )

  File.write(plugin_path, text) if text != original
end

post_install do |installer|
  patch_cloud_firestore_macos_plugin

  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '11.0'

      # Firebase Firestoreк°Җ лҒҢкі  мҳӨлҠ” gRPC-C++м—җм„ң CocoaPodsк°Җ мЎҙмһ¬н•ҳм§Җ м•ҠлҠ”
      # Private/grpc/gRPC-Core.modulemap кІҪлЎңлҘј мЈјмһ…н•ҳлҠ” кІҪмҡ°к°Җ мһҲлӢӨ.
      # мӢӨм ң modulemapмқҖ Target Support Files м•„лһҳм—җ мғқм„ұлҗҳлҜҖлЎң, к№Ём§„ м°ёмЎ°л§Ң м ңкұ°н•ңлӢӨ.
      ['OTHER_CFLAGS', 'OTHER_SWIFT_FLAGS', 'OTHER_LDFLAGS'].each do |key|
        flags = config.build_settings[key]
        next if flags.nil?

        if flags.is_a?(String)
          flags = flags.split(/\s+/)
        end

        filtered = flags.reject do |flag|
          flag.include?('Headers/Private/grpc/gRPC-Core.modulemap')
        end

        # FirebaseFirestoreInternalмқҖ м •м Ғ лқјмқҙлёҢлҹ¬лҰ¬(-lFirebaseFirestoreInternal)лЎң
        # л§ҒнҒ¬лҗҳлҠ”лҚ°, мқјл¶Җ CocoaPods мЎ°н•©м—җм„ң мЎҙмһ¬н•ҳм§Җ м•ҠлҠ” framework weak linkк°Җ
        # к°ҷмқҙ л“Өм–ҙк°Җ macOS л§Ғм»Өк°Җ мӢӨнҢЁн•ңлӢӨ.
        filtered = remove_weak_framework(filtered, 'FirebaseFirestoreInternal') if key == 'OTHER_LDFLAGS'

        config.build_settings[key] = filtered
      end

      if config.build_settings['MODULEMAP_FILE'] == 'Headers/Private/grpc/gRPC-Core.modulemap'
        config.build_settings['MODULEMAP_FILE'] = 'Target Support Files/gRPC-Core/gRPC-Core.modulemap'
      end
    end
  end

  Dir.glob(File.join(__dir__, 'Pods', 'Target Support Files', '**', '*.xcconfig')).each do |path|
    text = File.read(path)
    cleaned = text
      .gsub(/\s-Xcc\s-fmodule-map-file="\$\{PODS_ROOT\}\/Headers\/Private\/grpc\/gRPC-Core\.modulemap"/, '')
      .gsub(/\s-fmodule-map-file="\$\{PODS_ROOT\}\/Headers\/Private\/grpc\/gRPC-Core\.modulemap"/, '')
      .gsub(/\s-weak_framework\s+"?FirebaseFirestoreInternal"?/, '')

    File.write(path, cleaned) if cleaned != text
  end
end
