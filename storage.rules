rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/backups/{backupId}/{fileName} {
      allow read, write, delete: if isOwner(userId);
    }
  }
}
